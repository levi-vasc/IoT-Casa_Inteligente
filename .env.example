# IP do host onde o gateway está rodando.
# Para Docker no Linux, o IP padrão da bridge é 172.17.0.1.
# Se o gateway estiver em outra máquina na LAN, coloque o IP real dessa máquina.
#
# Exemplos:
#   GATEWAY_HOST=172.17.0.1        # gateway rodando no mesmo PC (Linux)
#   GATEWAY_HOST=192.168.1.100     # gateway em outro PC da rede LAN
GATEWAY_HOST=172.17.0.1
