# Configurações do gateway rodando nativamente no host Linux.
# Copie este arquivo para gateway/.env e ajuste conforme necessário.
#
# Endereços de escuta do gateway (0.0.0.0 = todas as interfaces de rede)
GATEWAY_CLIENT_ADDR=0.0.0.0:8080
GATEWAY_SENSOR_ADDR=0.0.0.0:8081
GATEWAY_ACTUATOR_ADDR=0.0.0.0:9000
